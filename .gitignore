# ════════════════════════════════════════════
# .gitignore — student-ai-impact-predictor
# ════════════════════════════════════════════

# ── Python ───────────────────────────────────
__pycache__/
*.py[oc]
*.pyo
*.pyd
build/
dist/
wheels/
*.egg-info/
.eggs/
*.so

# ── Virtual environments ─────────────────────
.venv/
venv/
env/
ENV/

# ── uv ───────────────────────────────────────
uv.lock
.python-version

# ── Jupyter ──────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Data (large files — not for GitHub) ──────
Data/raw/*.csv
Data/raw/*.xlsx
Data/raw/*.json
Data/processed/*.parquet
Data/processed/*.csv
Data/processed/*.feather
# keep directory markers
!Data/raw/.gitkeep
!Data/processed/.gitkeep
archive/

# ── Trained model artifacts ───────────────────
models/saved/**/*.pkl
models/saved/**/*.joblib
models/saved/**/*.h5
models/saved/**/*.pt
models/saved/**/*.onnx
!models/saved/.gitkeep

# ── Generated figures & reports ───────────────
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.svg
reports/figures/*.pdf
!reports/figures/.gitkeep

# ── Logs ─────────────────────────────────────
*.log
logs/
mlruns/               # MLflow tracking
.mlflow/

# ── Environment / secrets ────────────────────
.env
.env.*
*.secret
secrets.yaml

# ── OS files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / editor ─────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.spyderproject
.spyproject
.streamlit/secrets.toml
# ── Temporary / misc ─────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
