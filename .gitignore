# ── Python ───────────────────────────────────
__pycache__/
*.py[oc]
*.pyo
build/
dist/
wheels/
*.egg-info
.eggs/

# ── Virtual environments ─────────────────────
.venv/
venv/
env/

# ── Jupyter ──────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — keep raw small files, ignore large processed ──
Data/processed/*.parquet
Data/raw/*.csv          # large dataset — tracked via DVC or shared separately
!Data/raw/.gitkeep
!Data/processed/.gitkeep

# ── Model artifacts ──────────────────────────
models/saved/**/*.pkl
models/saved/**/*.joblib
!models/saved/.gitkeep

# ── Reports / figures — optional (uncomment to exclude) ──
# reports/figures/*.png

# ── uv / pip ─────────────────────────────────
uv.lock                 # commit this if you want reproducible installs
.python-version

# ── OS / IDE ─────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
